{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/greenticai/greentic-flow/refs/heads/master/schemas/ygtc.flow.schema.json",
  "title": "Greentic YGTC Flow (self-describing nodes)",
  "type": "object",
  "required": [
    "id",
    "type",
    "nodes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "type": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "messaging",
            "webhook",
            "timer",
            "websocket",
            "pubsub"
          ]
        },
        {
          "type": "string"
        }
      ],
      "description": "Flow kind; well-known values include 'messaging' and 'events', but custom strings (e.g., 'component-config') are allowed."
    },
    "start": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional namespaced metadata (e.g., meta.greentic.*)."
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional entrypoints keyed by name (e.g., default, telegram, http:/path)."
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "slot_schema": {
      "type": "array",
      "description": "Slot definitions for utterance-driven prefill. Consumed by the canonical M2 chain (Fast2Flow Dispatch{utterance} -> component-slot-extractor -> adaptive-card with prefill). Each entry mirrors component-slot-extractor's SlotDefinition.",
      "items": {
        "type": "object",
        "required": ["name", "slot_type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "slot_type": {
            "type": "string",
            "enum": ["string", "enum", "number", "date", "boolean"]
          },
          "pattern": {
            "type": "string",
            "description": "Optional regex; required for string slots."
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "enum_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_value": {
            "type": "string",
            "description": "Fallback when extraction yields no match; coerced per slot_type."
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": { "slot_type": { "const": "string" } },
              "required": ["slot_type"]
            },
            "then": {
              "required": ["pattern"],
              "properties": {
                "pattern": { "type": "string", "minLength": 1 }
              }
            }
          },
          {
            "if": {
              "properties": { "slot_type": { "const": "enum" } },
              "required": ["slot_type"]
            },
            "then": {
              "required": ["enum_values"],
              "properties": {
                "enum_values": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            }
          }
        ]
      }
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][\\w-]*$": {
          "type": "object",
          "minProperties": 1,
          "description": "Node keyed by human-friendly name; exactly one operation key plus optional metadata.",
          "properties": {
            "routing": {
              "description": "Routing can be shorthand or explicit list",
              "oneOf": [
                {
                  "type": "string",
                  "enum": [
                    "out",
                    "reply"
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "to": {
                        "type": "string"
                      },
                      "out": {
                        "type": "boolean"
                      },
                      "status": {
                        "type": "string"
                      },
                      "reply": {
                        "type": "boolean"
                      },
                      "condition": {
                        "type": "string",
                        "description": "Expression that must evaluate to true for this route to be taken"
                      }
                    }
                  }
                }
              ]
            },
            "telemetry": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "span_name": {
                  "type": "string"
                },
                "attributes": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "sampling": {
                  "type": "string"
                }
              }
            },
            "output": {
              "type": "object",
              "additionalProperties": true
            },
            "retry": {
              "type": "object"
            },
            "timeout": {
              "type": "object"
            },
            "when": {
              "type": "object"
            },
            "annotations": {
              "type": "object"
            },
            "meta": {
              "type": "object"
            }
          },
          "patternProperties": {
            "^[A-Za-z_][\\w-]*$": {
              "description": "Operation payload (exactly one op key is required).",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}